on": "semantically_similar_to", "confidence": "INFERRED", "confidence_score": 0.85, "source_file": "AGENTS.md", "source_location": "\u00a78", "weight": 1.0}, {"source": "agents_fire_alerts", "target": "agents_apptoast_fire", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "AGENTS.md", "source_location": "\u00a710.5", "weight": 1.0}, {"source": "agents_fire_alerts", "target": "agents_announcer", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "AGENTS.md", "source_location": "\u00a710.5", "weight": 1.0}, {"source": "agents_fire_alerts", "target": "agents_scheduler", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "AGENTS.md", "source_location": "\u00a710.5", "weight": 1.0}, {"source": "agents_fire_alerts", "target": "agents_clock", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "AGENTS.md", "source_location": "\u00a710.5", "weight": 1.0}, {"source": "agents_apptoast_fire", "target": "agents_apptoast", "relation": "implements", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "AGENTS.md", "source_location": "\u00a712", "weight": 1.0}, {"source": "agents_announcer", "target": "agents_offline_first", "relation": "conceptually_related_to", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "AGENTS.md", "source_location": "\u00a710.5", "weight": 1.0}, {"source": "agents_bloc", "target": "agents_clock", "relation": "references", "confidence": "INFERRED", "confidence_score": 0.85, "source_file": "AGENTS.md", "source_location": "\u00a79", "weight": 1.0}, {"source": "agents_go_router", "target": "agents_apptoast", "relation": "conceptually_related_to", "confidence": "INFERRED", "confidence_score": 0.75, "source_file": "AGENTS.md", "source_location": "\u00a77/\u00a712", "weight": 1.0}, {"source": "agents_multikot_jsx", "target": "agents_schedule_fn", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "AGENTS.md", "source_location": "\u00a710", "weight": 1.0}], "hyperedges": [{"id": "scheduler_placement_pipeline", "label": "Scheduler placement pipeline (batch/capacity/hold-late/lane)", "nodes": ["agents_schedule_fn", "agents_batching", "agents_hold_vs_late", "agents_lane_packing", "agents_plate_together"], "relation": "participate_in", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "AGENTS.md"}, {"id": "offline_first_data_flow", "label": "Offline-first write path (UI -> bloc -> repo -> Drift -> outbox -> sync)", "nodes": ["agents_bloc", "agents_repository", "agents_drift", "agents_outbox", "agents_sync_engine"], "relation": "form", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "AGENTS.md"}]}